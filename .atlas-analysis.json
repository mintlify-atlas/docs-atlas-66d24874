  "keyFeatures": [
    "Type-aware inline editing for all PostgreSQL data types",
    "Foreign key lookups with real-time search",
    "Git-like change management with commits and diff views",
    "SQL playground with CodeMirror editor and autocomplete",
    "Visual table schema builder with live SQL preview",
    "Advanced filtering with type-specific operators",
    "Multi-column sorting with shift-click",
    "Data import/export (CSV/JSON)",
    "ER diagram visualization",
    "Multi-project connection management with SSL support"
